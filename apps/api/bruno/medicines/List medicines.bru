meta {
  name: List medicines
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/medicines
  body: none
  auth: none
}

params:query {
  ~today: true
}

headers {
  x-user-id: {{devUserId}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("returns array", function() {
    expect(res.getBody()).to.be.an("array");
  });
}
