meta {
  name: Get medicine
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/medicines/{{medicineId}}
  body: none
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("returns id", function() {
    expect(res.getBody().id).to.be.a("string");
  });
  test("returns timings array", function() {
    expect(res.getBody().timings).to.be.an("array");
  });
}
