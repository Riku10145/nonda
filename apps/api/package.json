{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "doppler run -- sh -c 'wrangler dev --var DATABASE_URL:$DATABASE_URL --var FRONTEND_URL:http://localhost:3000 --var AUTH_SECRET:$AUTH_SECRET'",
    "lint": "oxlint src",
    "lint:github": "oxlint --format=github src",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "doppler run -- drizzle-kit migrate",
    "db:studio": "doppler run -- drizzle-kit studio"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@nonda/db": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "jose": "^6.2.3",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.1",
    "@types/node": "^25",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "^6",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  }
}
